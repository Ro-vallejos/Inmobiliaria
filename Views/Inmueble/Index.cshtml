@model IEnumerable<_net_integrador.Models.Inmueble>

@{
    ViewData["Title"] = "Inmuebles";
    var propietarioIdSeleccionado = ViewBag.PropietarioId as int?;
}

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="text-center">
    <h1 class="display-4">Lista de Inmuebles</h1>
</div>

<div class="card mb-4 bg-light shadow-sm">
    <div class="card-body">
        <h5 class="card-title text-secondary"><i class="bi bi-calendar-range"></i> Filtrar por Disponibilidad</h5>
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label for="fechaInicio" class="form-label font-weight-bold">Fecha de Inicio</label>
                <input type="date" name="fechaInicio" id="fechaInicio" class="form-control" 
                       value="@(ViewBag.FechaInicio != null ? ((DateTime)ViewBag.FechaInicio).ToString("yyyy-MM-dd") : "")" />
            </div>
            <div class="col-md-4">
                <label for="fechaFin" class="form-label font-weight-bold">Fecha de Fin</label>
                <input type="date" name="fechaFin" id="fechaFin" class="form-control" 
                       value="@(ViewBag.FechaFin != null ? ((DateTime)ViewBag.FechaFin).ToString("yyyy-MM-dd") : "")" />
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">
                    Filtrar Disponibles
                </button>
                @if (ViewBag.FechaInicio != null || ViewBag.FechaFin != null)
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
                }
            </div>
        </form>
    </div>
</div>

<p>
    <a class="btn btn-success" asp-action="Agregar">Agregar Inmueble</a>
    <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">Volver</a>
</p>

@if (ViewBag.Filtrado == true && !Model.Any())
{
    <div class="alert alert-warning text-center shadow-sm">
        <i class="bi bi-exclamation-triangle"></i> No hay inmuebles disponibles para el rango de fechas seleccionado.
    </div>
}

<table class="table table-striped" id="tablaInmuebles">
    <thead>
        <tr>
            <th>Código</th>
            <th>Propietario</th>
            <th>Dirección</th>
            <th>Uso</th>
            <th>Tipo</th>
            <th>Precio</th>
            <th>Ambientes</th>
            <th>Latitud</th>
            <th>Longitud</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var i in Model)
        {
            <tr>
                <td>@i.id</td>
                <td>@i.propietario?.NombreCompleto</td>
                <td>@i.direccion</td>
                <td>@i.uso</td>
                <td>@i.tipoInmueble?.tipo</td>
                <td>@i.precio?.ToString("C", new System.Globalization.CultureInfo("es-AR"))</td>
                <td>@i.ambientes</td>
                <td>@i.eje_y</td>
                <td>@i.eje_x</td>
                <td>
                    @if (i.estado == _net_integrador.Models.Estado.Disponible)
                    {
                        <span class="badge bg-success">Disponible</span>
                    }
                    else if (i.estado == _net_integrador.Models.Estado.Suspendido)
                    {
                        <span class="badge bg-warning text-dark">Suspendido</span>
                    }
                    else if (i.estado == _net_integrador.Models.Estado.Alquilado)
                    {
                        <span class="badge bg-danger">Alquilado</span>
                    }
                </td>
                <td>
                    @Html.ActionLink("Editar", "Editar", new { id = i.id }, new { @class = "btn btn-primary btn-sm" })
                    @if (i.estado != _net_integrador.Models.Estado.Suspendido )
                    {
                        @Html.ActionLink(
                            "Suspender",
                            "Suspender",
                            new { id = i.id },
                            new { @class = "btn btn-warning btn-sm", onclick = "return confirm('¿Seguro que querés suspender este inmueble?');" })
                      
                        @Html.ActionLink(
                            "Contrato",
                            "Agregar",
                            "Contrato",
                            new { idInmueble = i.id },
                            new { @class = "btn btn-success btn-sm" })
                            
                    }
                    else 
                    {
                        @Html.ActionLink(
                            "Activar",
                            "Activar",
                            new { id = i.id },
                            new { @class = "btn btn-success btn-sm", onclick = "return confirm('¿Seguro que querés activar este inmueble?');" })
                    }
                    
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaInmuebles').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.8/i18n/es-ES.json"
                },
                "columnDefs": [
                    { "orderable": false, "targets": 10 }
                ]
            });
        });
    </script>
}
