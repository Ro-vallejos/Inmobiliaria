@model IEnumerable<_net_integrador.Models.Pago>

@{
    ViewBag.Title = "Pagos del Contrato";
}

<div class="container mt-4">
    <h2>Pagos del Contrato</h2>

    <div class="mb-3">
        <a asp-action="Index" asp-controller="Contrato" class="btn btn-secondary">Volver a Contratos</a>
        @if (ViewBag.ContratoEstado != 0) 
        {
            <a asp-action="Agregar" asp-controller="Pago" asp-route-idContrato="@ViewBag.ContratoId" class="btn btn-success">Registrar Pago</a>
        }
    </div>

    <table class="table table-striped table-hover mt-3" id="tablaPagos">
        <thead>
            <tr>
                <th>Nro. de Pago</th>
                <th>Fecha de Pago</th>
                <th>Estado</th>
                <th>Monto</th>
                <th>Concepto</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pago in Model)
            {
                <tr>
                    <td>@(pago.nro_pago == 0 ? "Multa" : pago.nro_pago.ToString())</td>
                    <td>@(pago.fecha_pago?.ToShortDateString() ?? "Pendiente")</td>
                    <td>
                        @if (pago.estado == _net_integrador.Models.EstadoPago.pendiente)
                        {
                            <span class="badge bg-warning text-dark">Pendiente</span>
                        }
                        else if (pago.estado == _net_integrador.Models.EstadoPago.recibido)
                        {
                            <span class="badge bg-success">Recibido</span>
                        }
                        else if (pago.estado == _net_integrador.Models.EstadoPago.anulado)
                        {
                            <span class="badge bg-danger">Anulado</span>
                        }
                    </td>
                    <td>@pago.monto.ToString("C", new System.Globalization.CultureInfo("es-AR"))</td>
                    <td>@pago.concepto</td>
                    <td>
                        @if (pago.estado == _net_integrador.Models.EstadoPago.pendiente)
                        {
                            <form asp-action="Recibir" asp-controller="Pago" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@pago.id" />
                                @if (pago.nro_pago == 0)
                                {
                                    <button type="submit" class="btn btn-warning btn-sm">Recibir Pago Multa</button>
                                }
                                else if (ViewBag.ContratoEstado != 0)
                                {
                                    <button type="submit" class="btn btn-success btn-sm">Recibir</button>
                                }
                                else
                                {
                                    <small class="text-muted">Sin acciones disp.</small>

                                }
                            </form>
                        }

                        @if (pago.estado == _net_integrador.Models.EstadoPago.recibido)
                        {
                            @if (pago.nro_pago == 0)
                            {
                                <form asp-action="Anular" asp-controller="Pago" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@pago.id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Revertir Cobro</button>
                                </form>
                            }
                            else if (ViewBag.ContratoEstado != 0)
                            {
                                <form asp-action="Anular" asp-controller="Pago" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@pago.id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Anular</button>
                                </form>
                                
                                <a asp-action="Editar" asp-controller="Pago" asp-route-id="@pago.id" class="btn btn-primary btn-sm" style="display:inline-block;">
                                    Editar
                                </a>
                            }
                            else
                            {
                                <small class="text-muted">Sin acciones disp.</small>
                            }
                        }

                        @if (pago.estado == _net_integrador.Models.EstadoPago.anulado)
                        {
                            <small class="text-muted">Sin acciones disp.</small>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaPagos').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.8/i18n/es-ES.json"
                },
                "columnDefs": [
                    { "orderable": false, "targets": 5 }
                ]
            });
        });
    </script>
}